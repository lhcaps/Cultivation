# ===========================================
# Thiên Nam Engine — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control

# ── Application ──────────────────────────
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/thien_nam_engine?schema=public"
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/thien_nam_engine_test?schema=public"

# ── Redis ───────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Discord Bot ───────────────────────────
DISCORD_TOKEN="your_discord_bot_token_here"
DISCORD_CLIENT_ID="your_discord_client_id_here"
DISCORD_GUILD_ID="your_test_guild_id_here"
DISCORD_PUBLIC_LOG_CHANNEL_ID="your_public_log_channel_id_here"
API_BASE_URL="http://localhost:3000/api/v1"

# ── JWT / Auth ───────────────────────────
JWT_SECRET="your_jwt_secret_here_change_in_production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Admin Panel (NextAuth) ───────────────
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your_nextauth_secret_here_change_in_production"

# ── Game Config ──────────────────────────
GAME_DAILY_RESET_HOUR=0
GAME_SEASON_DURATION_DAYS=30
GAME_MAX_CHARACTERS_PER_USER=3
GAME_BREAKTHROUGH_COOLDOWN_DAYS=2
GAME_CULTIVATION_COOLDOWN_HOURS=1
GAME_SERVER_NAME="Thiên Nam Võ Lục"
GAME_PUBLIC_LOG_ENABLED=true

# ── BullMQ / Queue ───────────────────────
BULLMQ_CONCURRENCY=5
BULLMQ_LIMITS_MAX_ATTEMPTS=3

# ── External Services ─────────────────────
# Sentry DSN (optional)
SENTRY_DSN=""

# Cloudflare R2 / S3 for file storage (optional)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ── Development ───────────────────────────
DEBUG=false
LOG_LEVEL=info
