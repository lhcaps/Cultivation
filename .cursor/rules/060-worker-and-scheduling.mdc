## Job Structure

### Job Data

```typescript
interface SeclusionCompleteJob {
  characterId: string;
  startedAt: Date;
  expectedCompletionAt: Date;
  mode: "SECLUSION";
  basePoints: number;
  multiplier: number;
}
```

### Job Handler

```typescript
import { type Job } from "bullmq";

seclusionWorker.process(
  async (job: Job<SeclusionCompleteJob>) => {
    const { characterId, startedAt } = job.data;

    // Verify seclusion is actually complete
    const character = await prisma.character.findUnique({
      where: { id: characterId },
    });

    if (!character) {
      throw new Error(`Character ${characterId} not found`);
    }

    // Check if already processed (idempotency)
    const existingSession = await prisma.cultivationSession.findFirst({
      where: {
        characterId,
        mode: "SECLUSION",
        createdAt: { gte: startedAt },
      },
    });

    if (existingSession) {
      return { skipped: true, reason: "Already processed" };
    }

    // Process seclusion completion
    await prisma.$transaction(async (tx) => {
      await tx.character.update({
        where: { id: characterId },
        data: { cultivationPoints: { increment: job.data.basePoints * job.data.multiplier } },
      });
      await tx.cultivationSession.create({
        data: {
          characterId,
          mode: "SECLUSION",
          pointsGained: job.data.basePoints * job.data.multiplier,
          createdAt: new Date(),
        },
      });
    });

    return { success: true, pointsAwarded: job.data.basePoints * job.data.multiplier };
  }
);
```

