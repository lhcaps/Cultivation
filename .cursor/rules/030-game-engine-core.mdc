## Testing Requirements

Every rule function MUST have:

1. **Happy path test** — Normal usage works correctly.
2. **Edge case tests** — Zero values, max values, boundary conditions.
3. **Error case tests** — Invalid inputs throw appropriate errors.
4. **Formula verification** — Output matches expected mathematical results.

### Example Test Structure

```typescript
import { describe, it, expect } from "vitest";
import { calculateCultivationGain } from "./cultivation.js";

describe("calculateCultivationGain", () => {
  it("returns base gain for stable cultivation", () => {
    const gain = calculateCultivationGain(
      "LUYEN_THE",
      "STABLE",
      20,    // foundation
      "DAI_VIET",  // region
      0,     // heartDemon
      true,  // hasManual
      false, // inSect
    );
    // Luyện Thể base = 1000 × 0.8 × 1.0 × 1.0 × 1.0 × 1.0 = 800
    expect(gain).toBeGreaterThan(700);
    expect(gain).toBeLessThan(900);
  });

  it("increases gain with higher foundation quality", () => {
    const lowFQ = calculateCultivationGain("LUYEN_THE", "STABLE", 20, "DAI_VIET", 0, true, false);
    const highFQ = calculateCultivationGain("LUYEN_THE", "STABLE", 80, "DAI_VIET", 0, true, false);
    expect(highFQ).toBeGreaterThan(lowFQ);
  });

  it("throws error for invalid mode", () => {
    expect(() =>
      calculateCultivationGain("LUYEN_THE", "INVALID" as never, 20, "DAI_VIET", 0, true, false)
    ).toThrow();
  });
});
```

### RNG Injection

For testable randomness, accept an optional RNG:

```typescript
export function resolveBreakthrough(
  character: CharacterState,
  mode: BreakthroughMode,
  options: {
    rng?: () => number; // Default: Math.random
    currentTime?: number; // Default: Date.now()
  } = {},
): BreakthroughResult {
  const rng = options.rng ?? Math.random;
  const roll = rng();

  // Use roll for probability calculation
  // ...
}
```

In tests, pass a deterministic RNG:

```typescript
let callCount = 0;
const deterministicRng = () => {
  const values = [0.95, 0.30, 0.05]; // success, minor failure, severe
  return values[callCount++ % values.length]!;
};

const result = resolveBreakthrough(state, "STABLE", { rng: deterministicRng });
```

