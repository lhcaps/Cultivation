## Unit Tests (Vitest)

### Coverage Targets

| Package | Minimum Coverage |
|---------|----------------|
| `packages/core` | **90%** for rules |
| `packages/db` | N/A (migrations only) |
| `apps/api` | **70%** for services |
| `apps/worker` | **60%** for job handlers |

### Test Structure

```
packages/core/src/rules/
├── cultivation.test.ts    # Tests for cultivation rules
├── breakthrough.test.ts   # Tests for breakthrough rules
├── alchemy.test.ts       # Tests for alchemy rules
└── __fixtures__/         # Shared test fixtures
    ├── character-state.ts
    └── realm-data.ts
```

### Writing Tests

```typescript
import { describe, it, expect, vi } from "vitest";
import { calculateCultivationGain } from "./cultivation.js";
import type { CharacterState, CultivationMode } from "../types/index.js";

describe("calculateCultivationGain", () => {
  // Helper: create a minimal character state
  const makeCharacter = (overrides: Partial<CharacterState> = {}): CharacterState => ({
    id: "test-char-1",
    discordUserId: "user-1",
    name: "TestChar",
    realm: "LUYEN_THE",
    subStage: "SƠ",
    cultivationPoints: 0,
    foundationQuality: 20,
    heartDemon: 0,
    injuryLevel: 0,
    region: "DAI_VIET",
    sectId: null,
    manualId: "THANH_VAN_QUYET",
    currentHp: 100,
    maxHp: 100,
    currentQi: 50,
    maxQi: 50,
    silver: 500,
    spiritStones: 0,
    merit: 0,
    reputation: 0,
    heavenSeals: 0,
    luck: 10,
    element: "THUY",
    lastCultivationAt: null,
    lastHeartDemonAt: null,
    ...overrides,
  });

  describe("STABLE mode", () => {
    it("returns base gain for standard conditions", () => {
      const char = makeCharacter();
      const gain = calculateCultivationGain(char, "STABLE");
      // Luyện Thể base = 1000 × 0.8 = 800 ± variance
      expect(gain).toBeGreaterThan(700);
      expect(gain).toBeLessThan(900);
    });

    it("increases with higher foundation quality", () => {
      const lowFQ = makeCharacter({ foundationQuality: 20 });
      const highFQ = makeCharacter({ foundationQuality: 80 });
      expect(calculateCultivationGain(highFQ, "STABLE")).toBeGreaterThan(
        calculateCultivationGain(lowFQ, "STABLE"),
      );
    });

    it("decreases with high heart demon", () => {
      const normal = makeCharacter({ heartDemon: 0 });
      const corrupted = makeCharacter({ heartDemon: 90 });
      // High heart demon should reduce gain
      const normalGain = calculateCultivationGain(normal, "STABLE");
      const corruptedGain = calculateCultivationGain(corrupted, "STABLE");
      expect(corruptedGain).toBeLessThan(normalGain);
    });
  });

  describe("FORCED mode", () => {
    it("returns higher gain than STABLE", () => {
      const char = makeCharacter();
      expect(calculateCultivationGain(char, "FORCED")).toBeGreaterThan(
        calculateCultivationGain(char, "STABLE"),
      );
    });
  });

  describe("SECLUSION mode", () => {
    it("returns the highest multiplier", () => {
      const char = makeCharacter();
      const seclusionGain = calculateCultivationGain(char, "SECLUSION");
      const stableGain = calculateCultivationGain(char, "STABLE");
      expect(seclusionGain).toBeGreaterThan(stableGain * 2); // 3.0 vs 0.8
    });
  });
});
```

### Running Tests

```bash
pnpm test              # Run all tests
pnpm test:watch        # Watch mode
pnpm test:coverage     # Coverage report
pnpm --filter @thien-nam/core test  # Single package
```

